<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= title %></title>
<meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Spread Smile India is a registered NGO transforming lives through education, health, and vocational empowerment since 2005.' %>" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:title" content="<%= title %>" />
<meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Spread Smile India is a registered NGO transforming lives through education, health, and vocational empowerment since 2005.' %>" />
<meta property="og:image" content="https://ik.imagekit.io/l15cczdgu/Assets/logo.webp?updatedAt=1761388991377" />
<meta property="og:url" content="https://spreadasmileindia.org<%= typeof urlPath !== 'undefined' ? urlPath : '' %>" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:title" content="<%= title %>" />
<meta property="twitter:description" content="<%= typeof description !== 'undefined' ? description : 'Spread Smile India is a registered NGO transforming lives through education, health, and vocational empowerment since 2005.' %>" />
<meta property="twitter:image" content="https://ik.imagekit.io/l15cczdgu/Assets/logo.webp?updatedAt=1761388991377" />

<link rel="canonical" href="https://spreadasmileindia.org<%= typeof urlPath !== 'undefined' ? urlPath : '' %>" />

<!-- Theme Lock: Prevent Flash of White on Load -->
<script>
  (function() {
    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);
  })();
</script>

<!-- Google Fonts: Plus Jakarta Sans (body) + Cormorant Garamond (headings) + Cinzel (brand) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Cormorant+Garamond:wght@400;500;600;700&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet" />

<!-- Font Awesome 6 Free -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<!-- Base Styles -->
<link rel="stylesheet" href="/css/base.css" />
<link rel="stylesheet" href="/css/theme.css" />
<link rel="stylesheet" href="/css/navbar.css" />
<link rel="stylesheet" href="/css/footer.css" />
