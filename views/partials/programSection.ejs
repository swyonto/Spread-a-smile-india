<section id="<%= section.id %>" class="program-band<%= section.alt ? ' program-band--alt' : '' %>" data-program-section="<%= section.id %>">
  <div class="container">
    <div class="program-band__heading">
      <% if (section.label) { %>
        <p class="programs-kicker"><%= section.label %></p>
      <% } %>
      <h2><%= section.title %></h2>
      <% if (section.intro) { %>
        <p><%= section.intro %></p>
      <% } %>
    </div>

    <article class="program-main-card program-reveal">
      <div class="program-main-card__media">
        <img src="<%= section.main.image %>" alt="<%= section.main.alt %>" loading="lazy" />
      </div>
      <div class="program-main-card__content">
        <% if (section.main.tag) { %>
          <span class="program-card__tag"><%= section.main.tag %></span>
        <% } %>
        <h3><%= section.main.heading %></h3>
        <p><%= section.main.text %></p>

        <% if (section.main.points && section.main.points.length) { %>
          <ul class="program-points">
            <% section.main.points.forEach((point) => { %>
              <li><i class="fa-solid fa-check"></i> <%= point %></li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </article>

    <div class="program-support-grid">
      <% section.cards.forEach((card) => { %>
        <% if (card.type === 'video') { %>
          <article class="program-support-card program-support-card--video program-reveal" data-video-trigger data-video-src="<%= card.videoSrc %>" data-video-title="<%= card.videoTitle || card.title %>">
            <div class="program-support-card__media">
              <img src="<%= card.image %>" alt="<%= card.alt %>" loading="lazy" />
              <span class="program-card__play"><i class="fa-solid fa-play"></i></span>
            </div>
            <div class="program-support-card__content">
              <% if (card.tag) { %>
                <span class="program-card__tag"><%= card.tag %></span>
              <% } %>
              <h3><%= card.title %></h3>
              <p><%= card.text %></p>
            </div>
          </article>
        <% } else { %>
          <article class="program-support-card<%= card.tall ? ' program-support-card--tall' : '' %> program-reveal">
            <div class="program-support-card__media">
              <img src="<%= card.image %>" alt="<%= card.alt %>" loading="lazy" />
            </div>
            <div class="program-support-card__content">
              <% if (card.tag) { %>
                <span class="program-card__tag"><%= card.tag %></span>
              <% } %>
              <h3><%= card.title %></h3>
              <p><%= card.text %></p>
            </div>
          </article>
        <% } %>
      <% }) %>
    </div>
  </div>
</section>