<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/impact.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>

    <!-- Impact Stats -->
    <section class="impact-stats-section">
      <h2>Lives We've Touched</h2>
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number">5000+</span>
          <p class="stat-label">Lives Impacted</p>
        </div>
        <div class="stat-item">
          <span class="stat-number">1200+</span>
          <p class="stat-label">Children in School</p>
        </div>
        <div class="stat-item">
          <span class="stat-number">800+</span>
          <p class="stat-label">Women Empowered</p>
        </div>
        <div class="stat-item">
          <span class="stat-number">300+</span>
          <p class="stat-label">Job Placements</p>
        </div>
      </div>
    </section>

    <!-- Before / After Transformation -->
    <section class="impact-transformation-section">
      <h2>Real Transformation</h2>
      <div class="transformation-grid">
        <div class="transformation-item">
          <img src="https://ik.imagekit.io/l15cczdgu/transformation/transformation1.jpg" alt="Before transformation" loading="lazy" />
          <img src="https://ik.imagekit.io/l15cczdgu/transformation/IMG-20251126-WA0640.jpg" alt="After transformation" loading="lazy" />
        </div>
        <div class="transformation-item">
          <img src="https://ik.imagekit.io/l15cczdgu/transformation/transformation3.jpg" alt="Before transformation" loading="lazy" />
          <img src="https://ik.imagekit.io/l15cczdgu/transformation/IMG-20251126-WA0541.jpg" alt="After transformation" loading="lazy" />
        </div>
      </div>
    </section>

    <!-- Stories -->
    <section class="impact-stories-section">
      <h2>Real Stories. Real Change.</h2>
      <div class="stories-grid">
        <div class="story-item">
          <img src="https://ik.imagekit.io/l15cczdgu/story1.jpg" alt="Story" loading="lazy" />
          <p>From street child to college graduate — Priya's inspiring journey</p>
        </div>
        <div class="story-item">
          <img src="https://ik.imagekit.io/l15cczdgu/story2.jpg" alt="Story" loading="lazy" />
          <p>Women empowerment workshop — 12 new entrepreneurs born today!</p>
        </div>
        <div class="story-item">
          <img src="https://ik.imagekit.io/l15cczdgu/story3.jpg" alt="Story" loading="lazy" />
          <p>Free health camp reaching 150+ families in Delhi</p>
        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script src="/js/theme.js"></script>
</body>
</html>
