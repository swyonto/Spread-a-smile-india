<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/impact.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <main>

    <!-- ══════════════════════════════════════════════
         § 1  HERO + ANIMATED STATS
    ══════════════════════════════════════════════ -->
    <section class="impact-hero">
      <div class="impact-hero-inner">

        <span class="impact-tag-pill">Our Impact</span>
        <h1 class="impact-hero-heading">Lives Transformed Through Care & Education</h1>
        <p class="impact-hero-sub">
         Real Stories. Real Change.
        </p>

        <div class="impact-stats-row">
          <% stats.forEach(function(stat, i) { %>
            <div class="stat-box">
              <div class="stat-num-wrap">
                <span class="stat-num" data-target="<%= stat.target %>">0</span>
                <span class="stat-plus">+</span>
              </div>
              <p class="stat-lbl"><%= stat.label %></p>
            </div>
            <% if (i < stats.length - 1) { %>
              <div class="stat-divider"></div>
            <% } %>
          <% }); %>
        </div>

      </div>
      <div class="hero-blob hero-blob-1"></div>
      <div class="hero-blob hero-blob-2"></div>
    </section>


    <!-- ══════════════════════════════════════════════
         § 2  TRANSFORMATION CARDS (hover wipe reveal)
    ══════════════════════════════════════════════ -->
    <section class="impact-transform-section">
      <div class="impact-section-inner">

        <div class="impact-section-header">
          <span class="impact-tag-pill">Before &amp; After</span>
          <h2 class="impact-section-title">Real Transformations</h2>
          <p class="impact-section-sub">
            Hover over a card to reveal the transformation.
            These are real children — their journeys are real.
          </p>
        </div>

        <div class="transform-grid">
          <% transformCards.forEach(function(card) { %>
            <%- include('../partials/transformCard', card) %>
          <% }); %>
        </div>

      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         § 3  AUTO-SWIPING STORY SLIDER
    ══════════════════════════════════════════════ -->
    <section class="impact-stories-section">
      <div class="impact-section-inner">

        <div class="impact-section-header">
          <span class="impact-tag-pill">True Stories</span>
          <h2 class="impact-section-title">Their Journey. Their Voice.</h2>
          <p class="impact-section-sub">
            Real children, real change. Each card auto-advances — or use the arrows to explore.
          </p>
        </div>

        <div class="story-slider-wrap" id="storySliderWrap">

          <div class="story-track" id="storyTrack">
            <% stories.forEach(function(story) { %>
              <%- include('../partials/storySlide', story) %>
            <% }); %>
          </div>

          <button class="story-arrow story-prev" id="storyPrev" aria-label="Previous story">
            <i class="fa-solid fa-chevron-left"></i>
          </button>
          <button class="story-arrow story-next" id="storyNext" aria-label="Next story">
            <i class="fa-solid fa-chevron-right"></i>
          </button>

          <div class="story-progress-bar">
            <div class="story-progress-fill" id="storyProgress"></div>
          </div>

          <div class="story-dots" id="storyDots">
            <% stories.forEach(function(_, i) { %>
              <button
                class="story-dot <%= i === 0 ? 'active' : '' %>"
                data-index="<%= i %>"
                aria-label="Go to story <%= i + 1 %>"
              ></button>
            <% }); %>
          </div>

        </div>
      </div>
    </section>


    <!-- ══════════════════════════════════════════════
         § 4  CALL TO ACTION
    ══════════════════════════════════════════════ -->
    <section class="impact-cta-section">
      <div class="impact-cta-inner">
        <div class="impact-cta-icon"><i class="fa-solid fa-heart"></i></div>
        <h2 class="impact-cta-title">Be Part of the Next Transformation</h2>
        <p class="impact-cta-sub">
          Every rupee donated, every hour volunteered, every smile shared —
          moves a child closer to the life they deserve.
        </p>
        <div class="impact-cta-btns">
          <a href="/programs" class="impact-cta-btn impact-cta-btn--primary">
            <i class="fa-solid fa-seedling"></i> Explore Our Programs
          </a>
          <a href="/about" class="impact-cta-btn impact-cta-btn--secondary">
            <i class="fa-solid fa-users"></i> About Us
          </a>
        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script src="/js/theme.js"></script>
  <script src="/js/navbar.js"></script>
  <script src="/js/impact.js"></script>
</body>
</html>
