<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/skills.css" />
</head>

<body>

  <%- include('../partials/navbar') %>

    <main class="skills-page">

      <section class="skills-hero">
        <div class="skills-hero__glow skills-hero__glow--one"></div>
        <div class="skills-hero__glow skills-hero__glow--two"></div>

        <div class="container skills-hero__inner">
          <p class="skills-eyebrow">Empowerment Through Skills</p>
          <h1>Skill Development</h1>
          <p class="skills-hero__lead">
            Empowering communities and street children through practical, vocational, and creative units designed to
            build confidence, independence, and career options.
          </p>
        </div>
      </section>

      <section class="skills-overview">
        <div class="container">
          <div class="skills-overview__grid">
            <button class="skills-overview__card is-active" type="button" data-scroll-target="skill-tailoring">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/tailoring/tailoring_1.heic?updatedAt=1780858317385?tr=q-75"
                  alt="Tailoring unit" loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <i class="fa-solid fa-scissors"></i>
                <strong>Tailoring Unit</strong>
                <small>tailoring and embroidery.</small>
              </span>
            </button>

            <button class="skills-overview__card" type="button" data-scroll-target="skill-candle">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/candle/candle_1.jpg?tr=q-75" alt="Candle unit"
                  loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"
                  style="width: 1em; height: 1em; display: inline-block; vertical-align: middle; margin-top: -3px; color: var(--color-primary);">
                  <path d="M12 2c-.5 1-1.5 2.5-1.5 4a1.5 1.5 0 0 0 3 0c0-1.5-1-3-1.5-4z" fill="currentColor"
                    stroke="none" />
                  <rect x="10" y="10" width="4" height="9" rx="1.5" fill="currentColor" stroke="none" />
                  <path d="M5 20h11" />
                  <circle cx="18" cy="20" r="2" />
                </svg>
                <strong>Candle Unit</strong>
                <small>Scented candle crafting & sales.</small>
              </span>
            </button>

            <button class="skills-overview__card" type="button" data-scroll-target="skill-english">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/spoken_english/spoken_english_1.jpg?tr=q-75"
                  alt="Spoken English" loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <i class="fa-solid fa-language"></i>
                <strong>Spoken English</strong>
                <small>Fluency and conversational skills.</small>
              </span>
            </button>

            <button class="skills-overview__card" type="button" data-scroll-target="skill-dance">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/dance/dance_1.jpg?tr=q-75" alt="Dance workshop"
                  loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <i class="fa-solid fa-music"></i>
                <strong>Dance Workshop</strong>
                <small>Stage performance & expression.</small>
              </span>
            </button>

            <button class="skills-overview__card" type="button" data-scroll-target="skill-singing">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/Landing%20page/carouselSlides/image%207.jpg?tr=q-75"
                  alt="Singing unit" loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <i class="fa-solid fa-microphone"></i>
                <strong>Singing</strong>
                <small>Vocal music & choral practices.</small>
              </span>
            </button>

            <button class="skills-overview__card" type="button" data-scroll-target="skill-arts">
              <span class="skills-overview__image">
                <img src="https://ik.imagekit.io/l15cczdgu/art/art_1.jpg?tr=q-75" alt="Arts unit" loading="lazy" />
              </span>
              <span class="skills-overview__body">
                <i class="fa-solid fa-palette"></i>
                <strong>Arts</strong>
                <small>Painting, crafts, and origami.</small>
              </span>
            </button>
          </div>
        </div>
      </section>

      <% sections.forEach((section)=> { %>
        <%- include('../partials/skillSection', { section }) %>
          <% }) %>
    </main>

    <%- include('../partials/footer') %>

      <script src="/js/theme.js"></script>
      <script src="/js/skills.js"></script>
</body>

</html>