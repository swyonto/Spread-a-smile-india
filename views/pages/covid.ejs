<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <%- include('../partials/head') %>
  <link rel="stylesheet" href="/css/covid.css" />
</head>
<body>

  <%- include('../partials/navbar') %>

  <main class="covid-page">
    
    <!-- Hero Section -->
    <section class="covid-hero">
      <div class="covid-hero__glow covid-hero__glow--one"></div>
      <div class="covid-hero__glow covid-hero__glow--two"></div>
      <div class="container covid-hero__inner">
        <p class="covid-eyebrow">Relief Operations</p>
        <h1>COVID-19 Pandemic Response</h1>
        <p class="covid-hero__lead">
          During the unprecedented lockdowns and waves of the COVID-19 pandemic, Spread a Smile India mobilized immediate humanitarian aid to support thousands of daily-wage earners, street dwellers, and their families in Delhi NCR.
        </p>
      </div>
    </section>

    <!-- Narrative Section Removed per User Request -->

    <!-- Gallery Grid -->
    <section class="covid-gallery-section">
      <div class="container">
        <div class="covid-section-head">
          <p class="covid-eyebrow">On-the-ground Gallery</p>
          <h2>Moments of Relief & Hope</h2>
          <p>A visual record of our team's frontline efforts in food distribution, medical camps, hygiene support, and vaccine mobilization.</p>
        </div>

        <div class="covid-grid">
          
          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/nutrition/nutrition-1767865195461_zdhiieEsx.jpg" alt="Dry Rations Distribution" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Food Security</span>
              <h3>Dry Rations Distribution</h3>
              <p>Distributing monthly packages of rice, flour, pulses, oil, and spices to over 800 migrant families in Delhi slums.</p>
            </div>
          </div>

          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/health/image%203.jpg" alt="Mask & Sanitizer Distribution" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Hygiene Support</span>
              <h3>Masks & Hygiene Kits</h3>
              <p>Providing children and mothers with hand sanitizers, soaps, and high-filtration washable face masks to prevent viral transmission.</p>
            </div>
          </div>

          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/health/image%201.jpg" alt="Vaccine Awareness Camps" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Medical Awareness</span>
              <h3>Vaccination Mobilization</h3>
              <p>Partnering with local healthcare centers to register street dwellers on Government portals and hosting vaccine drives in our units.</p>
            </div>
          </div>

          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/nutrition/image%203.jpg" alt="Water & Cooked Food Deliveries" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Emergency Delivery</span>
              <h3>Cooked Food & Water Supply</h3>
              <p>Delivering fresh cooked meals and safe mineral water cans to communities near traffic signals cut off from supply chains.</p>
            </div>
          </div>

          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/education/academic/20251230_164855_eLpGfyFg0.jpg" alt="Home Study Material Kit Distribution" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Learning Continuity</span>
              <h3>Lockdown Study Kits</h3>
              <p>Distributing drawing pads, books, pencils, and educational worksheets to keep street children engaged and learning at home.</p>
            </div>
          </div>

          <div class="covid-card">
            <div class="covid-card__media">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/health/health-1767865132657_RW9g8QISfn.jpg" alt="Frontline Medical Checkups" loading="lazy" />
            </div>
            <div class="covid-card__content">
              <span class="covid-card__tag">Healthcare</span>
              <h3>Frontline Health Screenings</h3>
              <p>Conducting outdoor temperature checks, pulse-oximeter screenings, and general diagnostics to catch symptoms early.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Seamless Dense Image Grid (No Gaps) -->
    <section class="covid-seamless-grid-section">
      <div class="covid-seamless-grid">
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/nutrition/nutrition-1767865195461_zdhiieEsx.jpg" alt="Relief dry rations" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/health/image%203.jpg" alt="Hygiene kit distribution" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/health/image%201.jpg" alt="Vaccine mobilization camp" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/nutrition/image%203.jpg" alt="Cooked food relief deliveries" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/education/academic/20251230_164855_eLpGfyFg0.jpg" alt="Lockdown student study kits" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/programs/health/health-1767865132657_RW9g8QISfn.jpg" alt="Frontline health screening" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/Landing%20page/carouselSlides/image%209.jpg" alt="Delhi street children class" loading="lazy" />
        </div>
        <div class="covid-seamless-item">
          <img src="https://ik.imagekit.io/l15cczdgu/timeline/2025.jpg" alt="Children smiling in center" loading="lazy" />
        </div>
      </div>
    </section>

  </main>

  <%- include('../partials/footer') %>

  <script src="/js/theme.js"></script>
</body>
</html>
