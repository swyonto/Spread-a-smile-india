<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/covid.css" />
</head>

<body>

  <%- include('../partials/navbar') %>

    <main class="covid-page">

      <!-- Hero Section -->
      <section class="covid-hero">
        <div class="covid-hero__glow covid-hero__glow--one"></div>
        <div class="covid-hero__glow covid-hero__glow--two"></div>
        <div class="container covid-hero__inner">
          <p class="covid-eyebrow">Relief Operations</p>
          <h1>COVID-19 Pandemic Response</h1>
          <p class="covid-hero__lead">
            During the unprecedented lockdowns and waves of the COVID-19 pandemic, Spread a Smile India mobilized
            immediate humanitarian aid to support thousands of daily-wage earners, street dwellers, and their families
            in Delhi NCR.
          </p>
        </div>
      </section>

      <!-- Narrative Section Removed per User Request -->

      <!-- Gallery Grid -->
      <section class="covid-gallery-section">
        <div class="container">
          <div class="covid-section-head">
            <p class="covid-eyebrow">On-the-ground Gallery</p>
            <h2>Moments of Relief & Hope</h2>
            <p>A visual record of our team's frontline efforts in food distribution, medical camps, hygiene support, and
              vaccine mobilization.</p>
          </div>

          <div class="covid-grid">

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_2.jpg" alt="Dry Rations Distribution"
                  loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Food Security</span>
                <h3>Dry Rations Distribution</h3>
                <p>Distributing monthly packages of rice, flour, pulses, oil, and spices to over 800 migrant families in
                  Delhi slums.</p>
              </div>
            </div>

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_1.jpg"
                  alt="Mask & Sanitizer Distribution" loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Hygiene Support</span>
                <h3>Masks & Hygiene Kits</h3>
                <p>Providing children and mothers with hand sanitizers, soaps, and high-filtration washable face masks
                  to prevent viral transmission.</p>
              </div>
            </div>

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_3.jpg" alt="Vaccine Awareness Camps"
                  loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Medical Awareness</span>
                <h3>Vaccination Mobilization</h3>
                <p>Partnering with local healthcare centers to register street dwellers on Government portals and
                  hosting vaccine drives in our units.</p>
              </div>
            </div>

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_4.jpg"
                  alt="Water & Cooked Food Deliveries" loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Emergency Delivery</span>
                <h3>Cooked Food & Water Supply</h3>
                <p>Delivering fresh cooked meals and safe mineral water cans to communities near traffic signals cut off
                  from supply chains.</p>
              </div>
            </div>

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_5.jpg"
                  alt="Home Study Material Kit Distribution" loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Learning Continuity</span>
                <h3>Lockdown Study Kits</h3>
                <p>Distributing drawing pads, books, pencils, and educational worksheets to keep street children engaged
                  and learning at home.</p>
              </div>
            </div>

            <div class="covid-card">
              <div class="covid-card__media">
                <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_6.jpg"
                  alt="Frontline Medical Checkups" loading="lazy" />
              </div>
              <div class="covid-card__content">
                <span class="covid-card__tag">Healthcare</span>
                <h3>Frontline Health Screenings</h3>
                <p>Conducting outdoor temperature checks, pulse-oximeter screenings, and general diagnostics to catch
                  symptoms early.</p>
              </div>
            </div>

          </div>
        </div>
      </section>

      <!-- On-the-ground Video & Extra Gallery Section -->
      <section class="covid-extra-section">
        <div class="container">

          <div class="covid-extra-layout">

            <!-- Left: On-the-ground Video Player -->
            <div class="covid-video-container">
              <p class="covid-eyebrow">Featured Footage</p>
              <h2>Frontline Operations Footage</h2>
              <div class="covid-video-player-wrap">
                <video src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_1.mp4" controls
                  poster="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_15.jpg" preload="metadata">
                </video>
              </div>
              <p class="covid-video-desc">On-the-ground video footage highlighting dry rations distribution, medical
                checkups, and hygiene mobilization drives conducted by our team in under-resourced settlements in Delhi
                NCR.</p>
            </div>

            <!-- Right: Small Squarish Cards (No Text) -->
            <div class="covid-squarish-gallery-container">
              <p class="covid-eyebrow">More Moments</p>
              <h2>Photo Logs</h2>
              <div class="covid-squarish-grid">
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_16.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_17.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_18.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_19.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_20.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_21.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_22.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_23.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
                <div class="covid-squarish-card">
                  <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_24.jpg"
                    alt="Relief operation moment" loading="lazy" />
                </div>
              </div>
            </div>

          </div>

          <!-- Divider Line -->
          <hr class="covid-extra-divider" />

          <!-- Bottom: All Videos Card Grid (Reels-style, plays on hover) -->
          <div class="covid-videos-container">
            <p class="covid-eyebrow">On-the-ground Action</p>
            <h2>Helping in Pandemic</h2>
            <p class="covid-videos-lead">Explore our full archive of operational video journals documenting our team's
              relief drives, sanitization efforts, and local vaccination mobilization support during the lockdown waves.
              Hover to play, toggle volume individually.</p>

            <div class="covid-video-grid">
              <% for(let i=1; i <= 10; i++) { %>
                <div class="covid-video-card">
                  <div class="covid-video-card__player">
                    <video src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_<%= i %>.mp4" loop muted
                      playsinline preload="metadata"></video>

                    <div class="covid-video-controls-overlay">
                      <div class="covid-video-play-overlay">
                        <i class="fa-solid fa-play"></i>
                      </div>

                      <div class="covid-video-controls-bar">
                        <button type="button" class="covid-video-sound-btn" aria-label="Toggle sound">
                          <i class="fa-solid fa-volume-xmark"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
                <% } %>
            </div>
          </div>

        </div>
      </section>

      <!-- Seamless Dense Image Grid (No Gaps) -->
      <section class="covid-seamless-grid-section">
        <div class="covid-seamless-grid">
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_7.jpg" alt="Relief dry rations"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_8.jpg" alt="Hygiene kit distribution"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_9.jpg" alt="Vaccine mobilization camp"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_10.jpg"
              alt="Cooked food relief deliveries" loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_11.jpg" alt="Lockdown student study kits"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_12.jpg" alt="Frontline health screening"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_13.jpg" alt="Delhi street children class"
              loading="lazy" />
          </div>
          <div class="covid-seamless-item">
            <img src="https://ik.imagekit.io/l15cczdgu/programs/covid/covid_19_14.jpg" alt="Children smiling in center"
              loading="lazy" />
          </div>
        </div>
      </section>

    </main>

    <%- include('../partials/footer') %>

      <script src="/js/theme.js?v=1.0.2"></script>
      <script src="/js/covid.js?v=1.0.2"></script>
</body>

</html>