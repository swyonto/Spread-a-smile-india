<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/dignitaries.css" />
</head>

<body>

  <%- include('../partials/navbar') %>

    <main>

      <!-- Hero -->
      <section class="dg-hero">
        <div class="dg-hero-inner">
          <p class="dg-hero-label">Our Supporters</p>
          <h1 class="dg-hero-heading">Ambassadors &amp; Recognition</h1>
          <p class="dg-hero-sub">We are honoured by the support and recognition from distinguished individuals who
            believe in our mission to transform lives.</p>
        </div>
      </section>

      <!-- Recognition Cards -->
      <section class="dg-section">
        <div class="dg-list">

          <!-- 1: Kiren Rijiju -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador1.jpeg" alt="With Kiren Rijiju" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">Shri Kiren Rijiju</span>
                <span class="dg-title">Minister of State for Home Affairs, Govt. of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter1.jpg" data-lightbox-caption="Letter of Recognition from Shri Kiren Rijiju — March 2017">
                <img src="/assets/ambassadors/letter1.jpg" alt="Letter from Kiren Rijiju" loading="lazy" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Letter of Recognition &mdash; March 2017</p>
            </div>
          </div>

          <!-- 2: Kshenuka Senewiratne -->
          <div class="dg-card dg-card--flip dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador2.jpeg" alt="With Kshenuka Senewiratne" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Kshenuka Senewiratne</span>
                <span class="dg-title">High Commissioner, Democratic Socialist Republic of Sri Lanka</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter2.jpg" data-lightbox-caption="Letter of Recognition from High Commission of Sri Lanka — December 2024">
                <img src="/assets/ambassadors/letter2.jpg" alt="Letter from High Commission of Sri Lanka"
                  loading="lazy" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Letter of Recognition &mdash; December 2024</p>
            </div>
          </div>

          <!-- 3: Pattarat Hongtong -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador3.jpeg" alt="With Pattarat Hongtong" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Pattarat Hongtong</span>
                <span class="dg-title">Ambassador of the Kingdom of Thailand to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter3.jpg" data-lightbox-caption="Letter of Recommendation from Royal Thai Embassy — January 2025">
                <img src="/assets/ambassadors/letter3.jpg" alt="Letter from Royal Thai Embassy" loading="lazy" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Letter of Recommendation &mdash; January 2025</p>
            </div>
          </div>

          <!-- 4: Omar Lisandro Castaneda Solares -->
          <div class="dg-card dg-card--flip dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador4.jpg" alt="With H.E. Mr. Omar Lisandro Castaneda Solares"
                loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Mr. Omar Lisandro Castaneda Solares</span>
                <span class="dg-title">Ambassador of Guatemala to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-visit-info">
                <p class="dg-visit-tag">Special Visit</p>
                <h3 class="dg-visit-heading">A Memorable Visit to Spread a Smile India</h3>
                <p class="dg-visit-text">H.E. Mr. Omar Lisandro Castaneda Solares, Ambassador of the Republic of
                  Guatemala to India, made a heartwarming visit to Spread a Smile India. He spent quality time with our
                  children — engaging warmly, sharing stories, and celebrating their progress. His visit was a moment of
                  joy, inspiration, and international solidarity that our students will cherish for years to come.</p>
                <div class="dg-visit-badges">
                  <span class="dg-visit-badge"><i class="fa-solid fa-earth-americas"></i> Republic of Guatemala</span>
                  <span class="dg-visit-badge"><i class="fa-solid fa-children"></i> Met Our Students</span>
                </div>
              </div>
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter4.jpg" data-lightbox-caption="Letter of Appreciation from Embassy of Guatemala — 2025">
                <img src="/assets/ambassadors/letter4.jpg" alt="Letter from Embassy of Guatemala" loading="lazy" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Letter of Appreciation &mdash; 2025</p>
            </div>
          </div>

          <!-- 5: Philip Green -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/education/skill/20250502_153536_2qk1Ls_Ci.jpg" alt="With H.E. Philip Green" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Philip Green OAM</span>
                <span class="dg-title">Australian High Commissioner to India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-visit-info">
                <p class="dg-visit-tag">Special Visit</p>
                <h3 class="dg-visit-heading">Praising Vocational &amp; Tailoring Units</h3>
                <p class="dg-visit-text">H.E. Philip Green OAM visited our Munirka centers, inspecting the progress of the Tailoring and Digital Literacy Units. He commended the sustainable model of empowering local street mothers and older children to build livelihoods, describing it as a benchmark for community development.</p>
                <div class="dg-visit-badges">
                  <span class="dg-visit-badge"><i class="fa-solid fa-australia"></i> Australian High Commission</span>
                  <span class="dg-visit-badge"><i class="fa-solid fa-scissors"></i> Inspected Vocational Units</span>
                </div>
              </div>
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter4.jpg" data-lightbox-caption="Australian High Commission Visit Recommendation — 2025">
                <img src="/assets/ambassadors/letter4.jpg" alt="Australian High Commission Visit Recommendation" loading="lazy" style="filter: opacity(0.85);" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Visit Appreciation &mdash; 2025</p>
            </div>
          </div>

          <!-- 6: Thierry Mathou -->
          <div class="dg-card dg-card--flip dg-reveal">
            <div class="dg-card-photo">
              <img src="https://ik.imagekit.io/l15cczdgu/programs/celebrations/outside%20event.jpg" alt="With H.E. Thierry Mathou" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Thierry Mathou</span>
                <span class="dg-title">Ambassador of France to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-visit-info">
                <p class="dg-visit-tag">Special Visit</p>
                <h3 class="dg-visit-heading">Commending the Digital Transition</h3>
                <p class="dg-visit-text">H.E. Thierry Mathou expressed praise for the educational curriculum and digital learning laboratories. He observed a class session and commended our work in helping street children transition successfully from traffic signals into formal government school channels.</p>
                <div class="dg-visit-badges">
                  <span class="dg-visit-badge"><i class="fa-solid fa-cross"></i> Embassy of France</span>
                  <span class="dg-visit-badge"><i class="fa-solid fa-desktop"></i> Reviewed Computer Lab</span>
                </div>
              </div>
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter3.jpg" data-lightbox-caption="Embassy of France Visit Recommendation — 2025">
                <img src="/assets/ambassadors/letter3.jpg" alt="Embassy of France Recommendation" loading="lazy" style="filter: opacity(0.85);" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Visit Recommendation &mdash; 2025</p>
            </div>
          </div>

          <!-- 7: May-Elin Stener -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="https://ik.imagekit.io/l15cczdgu/Landing%20page/carouselSlides/20250419_170209.jpg" alt="With H.E. Ms. May-Elin Stener" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Ms. May-Elin Stener</span>
                <span class="dg-title">Ambassador of Norway to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-visit-info">
                <p class="dg-visit-tag">Special Visit</p>
                <h3 class="dg-visit-heading">Supporting Healthcare &amp; Women Empowerment</h3>
                <p class="dg-visit-text">H.E. Ms. May-Elin Stener visited our medical camp facilities and tailoring units. She expressed deep appreciation for the comprehensive care model which combines education with daily nutritious food, health screenings, and skill vocational certifications.</p>
                <div class="dg-visit-badges">
                  <span class="dg-visit-badge"><i class="fa-solid fa-flag"></i> Royal Norwegian Embassy</span>
                  <span class="dg-visit-badge"><i class="fa-solid fa-heart-pulse"></i> Reviewed Healthcare Camps</span>
                </div>
              </div>
              <div class="dg-letter-frame zoomable" data-lightbox-src="/assets/ambassadors/letter2.jpg" data-lightbox-caption="Royal Norwegian Embassy Commendation — 2025">
                <img src="/assets/ambassadors/letter2.jpg" alt="Royal Norwegian Embassy Commendation" loading="lazy" style="filter: opacity(0.85);" />
                <span class="dg-zoom-icon"><i class="fa-solid fa-magnifying-glass-plus"></i> Click to Zoom</span>
              </div>
              <p class="dg-letter-caption">Visit Appreciation &mdash; 2025</p>
            </div>
          </div>

        </div>
      </section>

    </main>

    <!-- Lightbox Modal for Zooming Recommendation Letters -->
    <div class="timeline-lightbox" id="timelineLightbox" aria-hidden="true" role="dialog">
      <div class="timeline-lightbox__backdrop" id="lightboxCloseBackdrop"></div>
      <div class="timeline-lightbox__dialog">
        <button class="timeline-lightbox__close" id="lightboxCloseBtn" type="button" aria-label="Close image">
          <i class="fa-solid fa-xmark"></i>
        </button>
        <div class="timeline-lightbox__media-wrap">
          <img id="lightboxImg" src="" alt="Zoomed Letter" />
        </div>
        <div class="timeline-lightbox__caption-bar">
          <p id="lightboxCaption">Appreciation Letter Details</p>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>

      <script src="/js/theme.js"></script>
      <script src="/js/navbar.js"></script>
      <script src="/js/dignitaries.js"></script>
</body>

</html>