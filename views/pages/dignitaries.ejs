<!DOCTYPE html>
<html lang="en">

<head>
  <%- include('../partials/head') %>
    <link rel="stylesheet" href="/css/dignitaries.css" />
</head>

<body>

  <%- include('../partials/navbar') %>

    <main>

      <!-- Hero -->
      <section class="dg-hero">
        <div class="dg-hero-inner">
          <p class="dg-hero-label">Our Supporters</p>
          <h1 class="dg-hero-heading">Ambassadors &amp; Recognition</h1>
          <p class="dg-hero-sub">We are honoured by the support and recognition from distinguished individuals who
            believe in our mission to transform lives.</p>
        </div>
      </section>

      <!-- Recognition Cards -->
      <section class="dg-section">
        <div class="dg-list">

          <!-- 1: Kiren Rijiju -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador1.jpeg" alt="With Kiren Rijiju" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">Shri Kiren Rijiju</span>
                <span class="dg-title">Minister of State for Home Affairs, Govt. of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame">
                <img src="/assets/ambassadors/letter1.jpg" alt="Letter from Kiren Rijiju" loading="lazy" />
              </div>
              <p class="dg-letter-caption">Letter of Recognition &mdash; March 2017</p>
            </div>
          </div>

          <!-- 2: Kshenuka Senewiratne -->
          <div class="dg-card dg-card--flip dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador2.jpeg" alt="With Kshenuka Senewiratne" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Kshenuka Senewiratne</span>
                <span class="dg-title">High Commissioner, Democratic Socialist Republic of Sri Lanka</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame">
                <img src="/assets/ambassadors/letter2.jpg" alt="Letter from High Commission of Sri Lanka"
                  loading="lazy" />
              </div>
              <p class="dg-letter-caption">Letter of Recognition &mdash; December 2024</p>
            </div>
          </div>

          <!-- 3: Pattarat Hongtong -->
          <div class="dg-card dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador3.jpeg" alt="With Pattarat Hongtong" loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Pattarat Hongtong</span>
                <span class="dg-title">Ambassador of the Kingdom of Thailand to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-letter-frame">
                <img src="/assets/ambassadors/letter3.jpg" alt="Letter from Royal Thai Embassy" loading="lazy" />
              </div>
              <p class="dg-letter-caption">Letter of Recommendation &mdash; January 2025</p>
            </div>
          </div>

          <!-- 4: Omar Lisandro Castaneda Solares -->
          <div class="dg-card dg-card--flip dg-reveal">
            <div class="dg-card-photo">
              <img src="/assets/ambassadors/ambassador4.jpg" alt="With H.E. Mr. Omar Lisandro Castaneda Solares"
                loading="lazy" />
              <div class="dg-card-name">
                <span class="dg-name">H.E. Mr. Omar Lisandro Castaneda Solares</span>
                <span class="dg-title">Ambassador of Guatemala to the Republic of India</span>
              </div>
            </div>
            <div class="dg-card-letter">
              <div class="dg-visit-info">
                <p class="dg-visit-tag">Special Visit</p>
                <h3 class="dg-visit-heading">A Memorable Visit to Spread a Smile India</h3>
                <p class="dg-visit-text">H.E. Mr. Omar Lisandro Castaneda Solares, Ambassador of the Republic of
                  Guatemala to India, made a heartwarming visit to Spread a Smile India. He spent quality time with our
                  children — engaging warmly, sharing stories, and celebrating their progress. His visit was a moment of
                  joy, inspiration, and international solidarity that our students will cherish for years to come.</p>
                <div class="dg-visit-badges">
                  <span class="dg-visit-badge"><i class="fa-solid fa-earth-americas"></i> Republic of Guatemala</span>
                  <span class="dg-visit-badge"><i class="fa-solid fa-children"></i> Met Our Students</span>
                </div>
              </div>
              <div class="dg-letter-frame">
                <img src="/assets/ambassadors/letter4.jpg" alt="Letter from Embassy of Guatemala" loading="lazy" />
              </div>
              <p class="dg-letter-caption">Letter of Appreciation &mdash; 2025</p>
            </div>
          </div>

        </div>
      </section>

    </main>

    <%- include('../partials/footer') %>

      <script src="/js/theme.js"></script>
      <script src="/js/navbar.js"></script>
      <script src="/js/dignitaries.js"></script>
</body>

</html>